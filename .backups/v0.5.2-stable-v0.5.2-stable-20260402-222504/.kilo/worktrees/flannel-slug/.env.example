# FlipIQ Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///data/flipiq.db

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# Backend Port
PORT=8000

# Frontend API URL (for production builds)
VITE_API_URL=http://localhost:8000/api

# Optional: Currency API key (for live rates)
# CURRENCY_API_KEY=your_api_key_here

# Optional: Cloud backup credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BACKUP_BUCKET=
