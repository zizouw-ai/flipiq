    {
      "name": "Data Isolation (CRITICAL)",
      "icon": "🔒",
      "description": "Verify users CANNOT see each other's data",
      "tests": [
        {
          "id": "ISO-001",
          "feature": "User 1 Creates Auction",
          "steps": [
            "Register as user1@test.com",
            "Login as User 1",
            "Create an auction named 'User1 Auction'",
            "Add items to the auction"
          ],
          "expected": "Auction and items created successfully",
          "status": "pending"
        },
        {
          "id": "ISO-002",
          "feature": "User 2 Cannot See User 1's Auction",
          "steps": [
            "Open incognito/private window",
            "Register as user2@test.com",
            "Login as User 2",
            "Go to Auction Tracker"
          ],
          "expected": "Auction list is EMPTY (no 'User1 Auction' visible)",
          "status": "pending",
          "critical": true
        },
        {
          "id": "ISO-003",
          "feature": "User 2 Cannot Access User 1's Items",
          "steps": [
            "As User 2, go to All Items"
          ],
          "expected": "Items list is EMPTY or shows only User 2's items",
          "status": "pending",
          "critical": true
        },
        {
          "id": "ISO-004",
          "feature": "User 2 Dashboard Isolated",
          "steps": [
            "As User 2, go to Dashboard"
          ],
          "expected": "Dashboard shows $0 revenue, no items (clean slate)",
          "status": "pending",
          "critical": true
        },
        {
          "id": "ISO-005",
          "feature": "User 1 Still Has Their Data",
          "steps": [
            "Go back to User 1's window",
            "Refresh the page"
          ],
          "expected": "User 1 still sees 'User1 Auction' and their items",
          "status": "pending",
          "critical": true
        }
      ]
    }
